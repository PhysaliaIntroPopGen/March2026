# ============================================
# Bootstrap Support Analysis for TreeMix m=1 to m=5
# ============================================
extract_migrations <- function(file) {
if (!file.exists(file)) return(NULL)
lines <- readLines(gzfile(file))
if (length(lines) < 2) return(NULL)
mig_lines <- lines[2:length(lines)]
edges <- list()
for (line in mig_lines) {
parts <- strsplit(line, "\\s+")[[1]]
parts <- parts[parts != ""]
if (length(parts) >= 6) {
edges[[length(edges) + 1]] <- list(
weight = as.numeric(parts[1]),
source = parts[5],
target = parts[6]
)
}
}
return(edges)
}
simplify_name <- function(tree_string) {
#pops <- regmatches(tree_string, gregexpr("P\\.[a-zA-Z_-]+", tree_string))[[1]]
pops <- regmatches(tree_string, gregexpr("P\\.[a-zA-Z_-]+", tree_string))[[1]]
if (length(pops) == 1) return(pops[1])
else return(paste0("clade(", paste(unique(pops), collapse=","), ")"))
}
edge_label <- function(source, target) {
paste(simplify_name(source), "→", simplify_name(target))
}
