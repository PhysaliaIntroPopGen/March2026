else return(paste0("clade(", paste(unique(pops), collapse=","), ")"))
}
edge_label <- function(source, target) {
paste(simplify_name(source), "→", simplify_name(target))
}
# ============================================
# Initialize results
# ============================================
all_results <- data.frame(
m = integer(), edge_number = integer(), migration_edge = character(),
weight = numeric(), bootstrap_support = integer(), support_percent = numeric(),
stringsAsFactors = FALSE
)
N_BOOT <- 5   # number of bootstrap replicates
# ============================================
# Analyze m=1 to m=5
# ============================================
for (m in 1:5) {
cat("=================================================\n")
cat(sprintf("=== TreeMix Bootstrap Support Analysis: m=%d ===\n", m))
cat("=================================================\n\n")
main_tree <- extract_migrations(paste0("../subset_Flowers_2019_treemix_mig_", m, ".treeout.gz"))
if (is.null(main_tree) || length(main_tree) == 0) {
cat(sprintf("WARNING: No migration edges found for m=%d\n\n", m)); next
}
cat(sprintf("Main tree (m=%d) has %d migration edge%s:\n",
m, length(main_tree), ifelse(length(main_tree)==1, "", "s")))
for (i in seq_along(main_tree)) {
cat(sprintf("  %d. %s (weight: %.3f)\n", i,
edge_label(main_tree[[i]]$source, main_tree[[i]]$target),
main_tree[[i]]$weight))
}
cat(sprintf("\nAnalyzing %d bootstrap replicates...\n\n", N_BOOT))
boot_edges <- list()
for (i in 1:N_BOOT) {
file  <- paste0("subset_Flowers_2019_treemix.", m, ".", i, ".treeout.gz")
edges <- extract_migrations(file)
if (!is.null(edges) && length(edges) > 0) {
boot_edges[[i]] <- lapply(edges, function(e) {
list(label  = edge_label(e$source, e$target),
weight = e$weight,
source = e$source,
target = e$target)
})
}
}
cat("Bootstrap support for main tree edges:\n")
cat("-------------------------------------------------------\n")
for (i in seq_along(main_tree)) {
main_edge     <- edge_label(main_tree[[i]]$source, main_tree[[i]]$target)
support_count <- 0
for (boot in boot_edges) {
if (is.null(boot)) next
if (main_edge %in% sapply(boot, function(x) x$label)) support_count <- support_count + 1
}
cat(sprintf("%d. %s\n", i, main_edge))
cat(sprintf("   Weight: %.3f\n", main_tree[[i]]$weight))
cat(sprintf("   Bootstrap support: %d/%d (%d%%)\n",
support_count, N_BOOT, round(support_count / N_BOOT * 100)))
cat("\n")
all_results <- rbind(all_results, data.frame(
m = m, edge_number = i, migration_edge = main_edge,
weight = main_tree[[i]]$weight,
bootstrap_support = support_count,
support_percent   = round(support_count / N_BOOT * 100),
stringsAsFactors  = FALSE
))
}
cat("\n")
}
# ============================================
# Bootstrap likelihood statistics
# ============================================
cat("\n=== Bootstrap Likelihood Statistics ===\n\n")
likelihood_stats <- data.frame(
m = integer(), mean_lnL = numeric(), sd_lnL = numeric(),
min_lnL = numeric(), max_lnL = numeric(), stringsAsFactors = FALSE
)
for (m in 1:5) {
likelihoods <- c()
for (i in 1:N_BOOT) {
llik_file <- paste0("subset_Flowers_2019_treemix.", m, ".", i,  ".llik")
if (file.exists(llik_file)) {
lines     <- readLines(llik_file)
llik_line <- grep("Exiting", lines, value=TRUE)
if (length(llik_line) > 0) {
parts         <- strsplit(llik_line, "\\s+")[[1]]
numeric_parts <- suppressWarnings(as.numeric(parts[parts != ""]))
numeric_parts <- numeric_parts[!is.na(numeric_parts)]
if (length(numeric_parts) > 0) likelihoods <- c(likelihoods, numeric_parts[length(numeric_parts)])
}
}
}
if (length(likelihoods) > 0) {
cat(sprintf("m=%d: Mean=%.2f, SD=%.2f, Range=%.2f to %.2f (N=%d/%d)\n",
m, mean(likelihoods), sd(likelihoods),
min(likelihoods), max(likelihoods), length(likelihoods), N_BOOT))
likelihood_stats <- rbind(likelihood_stats, data.frame(
m=m, mean_lnL=mean(likelihoods), sd_lnL=sd(likelihoods),
min_lnL=min(likelihoods), max_lnL=max(likelihoods), stringsAsFactors=FALSE
))
} else {
cat(sprintf("m=%d: No likelihood values found\n", m))
}
}
