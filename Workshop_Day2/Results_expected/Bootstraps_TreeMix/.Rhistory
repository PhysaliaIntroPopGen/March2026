simplify_name <- function(tree_string) {
#pops <- regmatches(tree_string, gregexpr("P\\.[a-zA-Z_-]+", tree_string))[[1]]
pops <- regmatches(tree_string, gregexpr("[a-zA-Z_-]+", tree_string))[[1]]
if (length(pops) == 1) return(pops[1])
else return(paste0("clade(", paste(unique(pops), collapse=","), ")"))
}
edge_label <- function(source, target) {
paste(simplify_name(source), "→", simplify_name(target))
}
